<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dorm.manage.mapper.ViolationMapper">
    <resultMap id="BaseResultMap" type="com.dorm.manage.entity.Violation">
        <id column="id" property="id"/>
        <result column="student_id" property="studentId"/>
        <result column="room_no" property="roomNo"/>
        <result column="violation_type" property="violationType"/>
        <result column="violation_time" property="violationTime"/>
        <result column="description" property="description"/>
        <result column="evidence" property="evidence"/>
        <result column="handle_result" property="handleResult"/>
        <result column="handler_id" property="handlerId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_violation (student_id, room_no, violation_type, violation_time, description, evidence, handle_result, handler_id)
        VALUES (#{studentId}, #{roomNo}, #{violationType}, #{violationTime}, #{description}, #{evidence}, #{handleResult}, #{handlerId})
    </insert>
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_violation WHERE id = #{id}
    </select>
    <select id="selectPage" resultMap="BaseResultMap">
        SELECT * FROM t_violation
        <where>
            <if test="studentId != null">AND student_id = #{studentId}</if>
            <if test="roomNo != null and roomNo != ''">AND room_no = #{roomNo}</if>
        </where>
        ORDER BY violation_time DESC
        LIMIT #{offset}, #{limit}
    </select>
    <select id="countPage" resultType="long">
        SELECT COUNT(*) FROM t_violation
        <where>
            <if test="studentId != null">AND student_id = #{studentId}</if>
            <if test="roomNo != null and roomNo != ''">AND room_no = #{roomNo}</if>
        </where>
    </select>
    <update id="updateById">
        UPDATE t_violation
        <set>
            <if test="handleResult != null">handle_result = #{handleResult},</if>
            <if test="handlerId != null">handler_id = #{handlerId},</if>
        </set>
        WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM t_violation WHERE id = #{id}
    </delete>
</mapper>
