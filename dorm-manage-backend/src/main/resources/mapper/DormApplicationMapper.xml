<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dorm.manage.mapper.DormApplicationMapper">
    <resultMap id="BaseResultMap" type="com.dorm.manage.entity.DormApplication">
        <id column="id" property="id"/>
        <result column="student_id" property="studentId"/>
        <result column="application_type" property="applicationType"/>
        <result column="original_room" property="originalRoom"/>
        <result column="target_room" property="targetRoom"/>
        <result column="reason" property="reason"/>
        <result column="attachment" property="attachment"/>
        <result column="status" property="status"/>
        <result column="reject_reason" property="rejectReason"/>
        <result column="audit_user_id" property="auditUserId"/>
        <result column="audit_time" property="auditTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_dorm_application (student_id, application_type, original_room, target_room, reason, attachment, status)
        VALUES (#{studentId}, #{applicationType}, #{originalRoom}, #{targetRoom}, #{reason}, #{attachment}, #{status})
    </insert>
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_dorm_application WHERE id = #{id}
    </select>
    <select id="selectByStudentId" resultMap="BaseResultMap">
        SELECT * FROM t_dorm_application WHERE student_id = #{studentId} ORDER BY create_time DESC
    </select>
    <select id="selectPage" resultMap="BaseResultMap">
        SELECT * FROM t_dorm_application
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="applicationType != null and applicationType != ''">AND application_type = #{applicationType}</if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>
    <select id="countPage" resultType="long">
        SELECT COUNT(*) FROM t_dorm_application
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="applicationType != null and applicationType != ''">AND application_type = #{applicationType}</if>
        </where>
    </select>
    <update id="updateById">
        UPDATE t_dorm_application
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="rejectReason != null">reject_reason = #{rejectReason},</if>
            <if test="auditUserId != null">audit_user_id = #{auditUserId},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
        </set>
        WHERE id = #{id}
    </update>
</mapper>
