<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dorm.manage.mapper.RepairMapper">

    <resultMap id="BaseResultMap" type="com.dorm.manage.entity.Repair">
        <id column="id" property="id"/>
        <result column="repair_no" property="repairNo"/>
        <result column="student_id" property="studentId"/>
        <result column="repair_type" property="repairType"/>
        <result column="room_no" property="roomNo"/>
        <result column="description" property="description"/>
        <result column="images" property="images"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="handler_id" property="handlerId"/>
        <result column="handler_name" property="handlerName"/>
        <result column="handle_remark" property="handleRemark"/>
        <result column="handle_images" property="handleImages"/>
        <result column="complete_time" property="completeTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="studentWhere">
        <where>
            student_id = #{studentId}
            <if test="status != null">AND status = #{status}</if>
            <if test="repairType != null and repairType != ''">AND repair_type = #{repairType}</if>
            <if test="startTime != null">AND create_time &gt;= #{startTime}</if>
            <if test="endTime != null">AND create_time &lt;= #{endTime}</if>
        </where>
    </sql>

    <sql id="adminWhere">
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="repairType != null and repairType != ''">AND repair_type = #{repairType}</if>
            <if test="buildingNo != null and buildingNo != ''">AND room_no LIKE CONCAT(#{buildingNo}, '%')</if>
            <if test="handlerId != null">AND handler_id = #{handlerId}</if>
            <if test="startTime != null">AND create_time &gt;= #{startTime}</if>
            <if test="endTime != null">AND create_time &lt;= #{endTime}</if>
        </where>
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_repair (repair_no, student_id, repair_type, room_no, description, images, phone, status)
        VALUES (#{repairNo}, #{studentId}, #{repairType}, #{roomNo}, #{description}, #{images}, #{phone}, #{status})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_repair WHERE id = #{id}
    </select>

    <select id="selectByRepairNo" resultMap="BaseResultMap">
        SELECT * FROM t_repair WHERE repair_no = #{repairNo}
    </select>

    <select id="selectByStudentId" resultMap="BaseResultMap">
        SELECT * FROM t_repair
        <include refid="studentWhere"/>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByStudentId" resultType="long">
        SELECT COUNT(*) FROM t_repair
        <include refid="studentWhere"/>
    </select>

    <select id="selectPage" resultMap="BaseResultMap">
        SELECT * FROM t_repair
        <include refid="adminWhere"/>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countPage" resultType="long">
        SELECT COUNT(*) FROM t_repair
        <include refid="adminWhere"/>
    </select>

    <update id="updateById">
        UPDATE t_repair
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="handlerId != null">handler_id = #{handlerId},</if>
            <if test="handlerName != null">handler_name = #{handlerName},</if>
            <if test="handleRemark != null">handle_remark = #{handleRemark},</if>
            <if test="handleImages != null">handle_images = #{handleImages},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="countByType" resultType="map">
        SELECT repair_type AS name, COUNT(*) AS value
        FROM t_repair
        <where>
            <if test="startTime != null">AND create_time &gt;= #{startTime}</if>
            <if test="endTime != null">AND create_time &lt;= #{endTime}</if>
        </where>
        GROUP BY repair_type
    </select>

    <select id="countByBuilding" resultType="map">
        SELECT SUBSTRING_INDEX(room_no, '-', 1) AS name, COUNT(*) AS value
        FROM t_repair
        <where>
            <if test="startTime != null">AND create_time &gt;= #{startTime}</if>
            <if test="endTime != null">AND create_time &lt;= #{endTime}</if>
        </where>
        GROUP BY SUBSTRING_INDEX(room_no, '-', 1)
    </select>
</mapper>
